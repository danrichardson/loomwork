---
import "../styles/global.css";
import "../styles/themes.css";
import "../styles/site.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReaderControls from "../components/ReaderControls.astro";
import ReadingEnhancements from "../components/ReadingEnhancements.astro";
import { SITE } from "../site.config";
import { THEMES } from "../themes/_index";
import type { ThemeName } from "../themes/_index";

interface Props {
  title: string;
  description?: string;
  og_image?: string;
  noindex?: boolean;
  class?: string;
}

const {
  title,
  description = SITE.description,
  og_image,
  noindex = false,
  class: className = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const pageTitle = title === SITE.name ? title : `${title} - ${SITE.name}`;
const showReaderControls = (SITE as any).reader_controls ?? false;

// Theme system: resolve theme from config, load its fonts
const themeName = ((SITE as any).theme || "") as string;
const themeEntry = themeName && themeName in THEMES ? THEMES[themeName as ThemeName] : null;
// User's fonts_url overrides theme fonts; theme fonts override empty
const fontsUrl = SITE.fonts_url || themeEntry?.fonts_url || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {og_image && <meta property="og:image" content={new URL(og_image, SITE.url)} />}

    <!-- Fonts preconnect (always needed) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Theme registry for client-side picker -->
    {showReaderControls && (
      <script
        id="lw-theme-map"
        type="application/json"
        set:html={JSON.stringify({
          defaultTheme: themeName,
          themes: Object.fromEntries(
            Object.entries(THEMES).map(([k, v]) => [k, { fonts_url: v.fonts_url, tagline: v.tagline }])
          ),
        })}
      />
    )}

    {/*
      FOUC prevention — runs synchronously in <head> before any paint.
      1. Applies data-attributes (dark, font-size, toc, width, zen) on <html>.
      2. Uses document.write() to emit the correct theme <link> and fonts <link>
         based on the user's saved preference.  document.write inside an inline
         <head> script produces render-blocking stylesheets, so the browser will
         not paint until the correct theme CSS has loaded.  This eliminates the
         flash entirely — no wrong stylesheet is ever fetched.
      3. Falls back to the site default theme/fonts when no preference is saved.
    */}
    <meta id="lw-defaults" data-theme={themeName || ""} data-fonts={fontsUrl || ""} />
    <script is:inline>
      (function() {
        try {
          var p = JSON.parse(localStorage.getItem("lw-reader") || "{}");
          var d = document.documentElement;
          if (p.dark === "true") d.setAttribute("data-dark", "true");
          else if (p.dark === "false") d.setAttribute("data-dark", "false");
          if (p.fontSize && p.fontSize !== "md") d.setAttribute("data-font-size", p.fontSize);
          if (p.toc === "hidden") d.setAttribute("data-toc", "hidden");
          else if (p.toc === "numbered") d.setAttribute("data-toc", "numbered");
          if (p.width && p.width !== "default") d.setAttribute("data-width", p.width);
          if (p.zen === "true") d.setAttribute("data-zen", "");
        } catch(e) {}
      })();
    </script>
    <script is:inline>
      (function() {
        var el = document.getElementById("lw-defaults");
        var defaultTheme = el ? el.getAttribute("data-theme") : "";
        var defaultFonts = el ? el.getAttribute("data-fonts") : "";
        var theme = defaultTheme;
        var fonts = defaultFonts;
        try {
          var p = JSON.parse(localStorage.getItem("lw-reader") || "{}");
          if (p.theme) {
            theme = p.theme;
            // Look up fonts for the chosen theme
            try {
              var m = JSON.parse(document.getElementById("lw-theme-map").textContent);
              var t = m && m.themes && m.themes[p.theme];
              if (t && t.fonts_url) fonts = t.fonts_url;
            } catch(e2) {}
          }
        } catch(e) {}
        if (theme && /^[a-z]+$/.test(theme)) {
          document.write('<link id="lw-theme" rel="stylesheet" href="/themes/' + theme + '.css">');
        }
        if (fonts && fonts.indexOf('https://fonts.googleapis.com/') === 0) {
          document.write('<link id="lw-fonts" rel="stylesheet" href="' + fonts + '">');
        }
      })();
    </script>
    <noscript>
      <link id="lw-theme" rel="stylesheet" href={themeEntry ? `/themes/${themeName}.css` : undefined} />
      <link id="lw-fonts" rel="stylesheet" href={fontsUrl || undefined} />
    </noscript>
  </head>

  <body class:list={[className ? `body--${className}` : ""]}>
    <Header />
    <main class={className}>
      <slot />
    </main>
    {className !== "longform" && <Footer />}
    {showReaderControls && <ReadingEnhancements />}
    {showReaderControls && <ReaderControls />}
  </body>
</html>
