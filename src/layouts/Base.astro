---
import "../styles/global.css";
import "../styles/themes.css";
import "../styles/site.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReaderControls from "../components/ReaderControls.astro";
import ReadingEnhancements from "../components/ReadingEnhancements.astro";
import { SITE } from "../site.config";
import { THEMES } from "../themes/_index";
import type { ThemeName } from "../themes/_index";

interface Props {
  title: string;
  description?: string;
  og_image?: string;
  noindex?: boolean;
  class?: string;
}

const {
  title,
  description = SITE.description,
  og_image,
  noindex = false,
  class: className = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const pageTitle = title === SITE.name ? title : `${title} - ${SITE.name}`;
const showReaderControls = (SITE as any).reader_controls ?? false;

// Theme system: resolve theme from config, load its fonts
const themeName = ((SITE as any).theme || "") as string;
const themeEntry = themeName && themeName in THEMES ? THEMES[themeName as ThemeName] : null;
// User's fonts_url overrides theme fonts; theme fonts override empty
const fontsUrl = SITE.fonts_url || themeEntry?.fonts_url || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {og_image && <meta property="og:image" content={new URL(og_image, SITE.url)} />}

    <!-- Fonts: resolved by inline script below to prevent FOUC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link id="lw-fonts" rel="stylesheet" />

    <!-- Theme CSS (resolved by inline script below to prevent FOUC) -->
    <link id="lw-theme" rel="stylesheet" />
    <!-- Defaults for the inline script to use as fallback -->
    <meta id="lw-default-theme" content={themeName || ""} />
    <meta id="lw-default-fonts" content={fontsUrl || ""} />

    <!-- Theme registry for client-side picker -->
    {showReaderControls && (
      <script
        id="lw-theme-map"
        type="application/json"
        set:html={JSON.stringify({
          defaultTheme: themeName,
          themes: Object.fromEntries(
            Object.entries(THEMES).map(([k, v]) => [k, { fonts_url: v.fonts_url, tagline: v.tagline }])
          ),
        })}
      />
    )}

    {/* FOUC prevention: apply saved reader prefs before paint */}
    <script is:inline>
      (function() {
        try {
          var p = JSON.parse(localStorage.getItem("lw-reader") || "{}");
          var d = document.documentElement;
          if (p.dark === "true") d.setAttribute("data-dark", "true");
          else if (p.dark === "false") d.setAttribute("data-dark", "false");
          if (p.fontSize && p.fontSize !== "md") d.setAttribute("data-font-size", p.fontSize);
          if (p.toc === "hidden") d.setAttribute("data-toc", "hidden");
          else if (p.toc === "numbered") d.setAttribute("data-toc", "numbered");
          if (p.width && p.width !== "default") d.setAttribute("data-width", p.width);
          if (p.zen === "true") d.setAttribute("data-zen", "");
          // Resolve theme: user preference wins, then site default
          var defaultTheme = (document.getElementById("lw-default-theme") || {}).content || "";
          var theme = p.theme || defaultTheme;
          if (theme) {
            var tl = document.getElementById("lw-theme");
            if (tl) tl.setAttribute("href", "/themes/" + theme + ".css");
          }
          // Resolve fonts: user's theme fonts, else site default fonts
          var defaultFonts = (document.getElementById("lw-default-fonts") || {}).content || "";
          var fontsUrl = defaultFonts;
          if (p.theme) {
            try {
              var m = JSON.parse(document.getElementById("lw-theme-map").textContent);
              var t = m && m.themes && m.themes[p.theme];
              if (t && t.fonts_url) fontsUrl = t.fonts_url;
            } catch(e2) {}
          }
          if (fontsUrl) {
            var fl = document.getElementById("lw-fonts");
            if (fl) fl.setAttribute("href", fontsUrl);
          }
        } catch(e) {}
      })();
    </script>
  </head>

  <body class:list={[className ? `body--${className}` : ""]}>
    <Header />
    <main class={className}>
      <slot />
    </main>
    {className !== "longform" && <Footer />}
    {showReaderControls && <ReadingEnhancements />}
    {showReaderControls && <ReaderControls />}
  </body>
</html>
