---
/**
 * Longform.astro - Split-panel layout for long-form content
 *
 * Part of the Loomwork framework.
 * Used when template: "longform" is set in frontmatter.
 *
 * Desktop: Article index sidebar on the left, wide content panel on the right.
 * Mobile: Collapsible article index above content.
 *
 * The article index lists all sibling pages that share the same `section` value,
 * giving a persistent navigation for multi-article deep dives.
 */
import Base from "./Base.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description: string;
  section?: string;
  hero_image?: string;
  hero_alt?: string;
  date_updated?: Date;
  headings?: { depth: number; slug: string; text: string }[];
  body?: string;
  /** The current page slug for highlighting in the index */
  currentSlug?: string;
}

const {
  title,
  description,
  section,
  hero_image,
  hero_alt,
  date_updated,
  headings = [],
  body = "",
  currentSlug = "",
} = Astro.props;

/* Reading time estimate */
const wordCount = body ? body.trim().split(/\s+/).length : 0;
const readingTime = wordCount > 0 ? Math.max(1, Math.round(wordCount / 230)) : 0;

/* Fetch sibling articles in the same section for the index sidebar */
let siblings: { title: string; slug: string; nav_order: number; nav_title?: string }[] = [];
if (section) {
  const allPages = await getCollection("pages", ({ data }) =>
    !data.draft && data.section === section && data.template === "longform"
  );
  siblings = allPages
    .map((p) => ({
      title: p.data.nav_title || p.data.title,
      slug: "/" + p.id.replace(/\.mdx?$/, ""),
      nav_order: p.data.nav_order ?? 100,
    }))
    .sort((a, b) => a.nav_order - b.nav_order);
}
---

<Base title={title} description={description} class="longform">
  <div class="longform">
    {/* ── Article index sidebar ──────────────────────── */}
    {siblings.length > 1 && (
      <aside class="longform__index">
        <div class="longform__index-inner">
          {/* Mobile: collapsible toggle */}
          <button
            class="longform__index-toggle"
            aria-expanded="false"
            aria-controls="longform-index-list"
          >
            <span class="longform__index-section">{section}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {/* Article list */}
          <nav id="longform-index-list" class="longform__index-nav" aria-label="Article index">
            <p class="longform__index-title">{section}</p>
            <ol class="longform__index-list">
              {siblings.map((s, i) => (
                <li>
                  <a
                    href={s.slug}
                    class:list={["longform__index-link", { "is-active": s.slug === "/" + currentSlug }]}
                    aria-current={s.slug === "/" + currentSlug ? "page" : undefined}
                  >
                    <span class="longform__index-num">{i + 1}</span>
                    <span>{s.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
      </aside>
    )}

    {/* ── Content panel ──────────────────────────────── */}
    <article class="longform__content">
      {/* Hero */}
      {hero_image && (
        <div class="longform__hero">
          <img src={hero_image} alt={hero_alt || ""} loading="eager" />
        </div>
      )}

      <header class="longform__header">
        <h1>{title}</h1>
        <div class="longform__meta text-muted text-sm">
          {readingTime > 0 && (
            <span>{readingTime} min read</span>
          )}
          {date_updated && readingTime > 0 && (
            <span aria-hidden="true">&middot;</span>
          )}
          {date_updated && (
            <span>Updated {date_updated.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}</span>
          )}
        </div>
      </header>

      <div class="longform__body prose">
        <slot />
      </div>
    </article>
  </div>
</Base>

<style>
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     LONGFORM LAYOUT
     Split-panel: index sidebar + wide content area.
     Viewport-fitted with internal scroll.
     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .longform {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 4rem); /* viewport-fitted: fills below header */
    overflow: hidden; /* prevent page-level scroll */
  }

  /* ── Index sidebar ───────────────────────────────────── */
  .longform__index {
    border-block-end: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .longform__index-inner {
    padding: var(--space-md) var(--space-lg);
  }

  /* Section title (desktop only) */
  .longform__index-title {
    display: none;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-block-end: var(--space-sm);
  }

  /* Mobile toggle */
  .longform__index-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-xs) 0;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .longform__index-toggle svg {
    transition: transform var(--transition);
  }
  .longform__index-toggle[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  /* Nav list */
  .longform__index-nav {
    display: none;
  }
  .longform__index-nav.is-open {
    display: block;
  }

  .longform__index-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .longform__index-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: 1.4;
    transition: all var(--transition);
  }
  .longform__index-link:hover {
    background: var(--color-surface);
    color: var(--color-accent);
  }
  .longform__index-link.is-active {
    background: var(--color-accent);
    color: white;
  }

  .longform__index-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.6875rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .longform__index-link.is-active .longform__index-num {
    background: rgba(255,255,255,0.2);
    color: white;
  }

  /* ── Content panel ───────────────────────────────────── */
  .longform__content {
    flex: 1;
    padding: var(--space-lg);
    overflow-y: auto;
    width: 100%;
    background: var(--color-bg);
  }

  /* Constrain inner content, not the scroll container */
  .longform__header,
  .longform__body,
  .longform__hero {
    max-width: var(--wide-width);
    margin-inline: auto;
  }

  .longform__hero {
    max-height: 20rem;
    overflow: hidden;
    border-radius: var(--radius);
    margin-block-end: var(--space-lg);
  }
  .longform__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .longform__header {
    padding-block-end: var(--space-lg);
    border-block-end: 1px solid var(--color-border);
    margin-block-end: var(--space-xl);
  }
  .longform__header h1 {
    font-size: var(--text-3xl);
    letter-spacing: -0.025em;
    margin-block-end: var(--space-xs);
  }

  .longform__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .longform__body {
    padding-block-end: var(--space-2xl);
  }

  /* ── Desktop: side-by-side layout ────────────────────── */
  @media (min-width: 960px) {
    .longform {
      flex-direction: row;
      height: calc(100vh - 4rem);
    }

    /* Sidebar */
    .longform__index {
      width: 260px;
      min-width: 260px;
      border-block-end: none;
      border-inline-end: 1px solid var(--color-border);
      overflow-y: auto;
    }
    .longform__index-inner {
      padding: var(--space-lg);
      position: sticky;
      top: 0;
    }

    /* Always show nav on desktop */
    .longform__index-toggle {
      display: none;
    }
    .longform__index-nav {
      display: block !important;
    }
    .longform__index-title {
      display: block;
    }

    /* Content fills remaining space */
    .longform__content {
      flex: 1;
      overflow-y: auto;
      padding: var(--space-xl) var(--space-2xl);
    }

    .longform__header,
    .longform__body,
    .longform__hero {
      max-width: var(--wide-width);
    }

    .longform__header h1 {
      font-size: clamp(2rem, 4vw, 3rem);
    }
  }

  /* ── Print ───────────────────────────────────────────── */
  @media print {
    .longform__index { display: none; }
    .longform { height: auto; }
    .longform__content { overflow: visible; }
  }
</style>

<script>
  // Mobile index toggle
  const toggle = document.querySelector('.longform__index-toggle');
  const nav = document.querySelector('.longform__index-nav');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('is-open');
    });

    // Close on link click (mobile)
    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('is-open');
      });
    });
  }
</script>
