---
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// HOMEPAGE - SITE-SPECIFIC FILE
//
// This file is YOURS. Customize the layout, hero, CTAs,
// and content for your site. It won't conflict with
// framework updates from the loomwork repo.
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
import Base from "../layouts/Base.astro";
import { SITE } from "../site.config";
---

<Base title={SITE.name}>
  <section class="hero">
    <div class="container">
      <h1 class="hero__title">
        <img class="hero__icon" src="/icons/loom.svg" alt="" width="40" height="40" />
        {SITE.name}
      </h1>
      <p class="hero__tagline">{SITE.tagline}</p>
      <p class="hero__description">{SITE.description}</p>

      <div class="hero__actions">
        {SITE.nav.map((item) => (
          <a href={item.href} class="btn btn--secondary">{item.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="features">
    <div class="features__rotator" aria-live="polite">
      <div class="features__item is-active">
        <img src="/icons/themes.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>10 Built-in Themes</h3>
        <p>Manuscript, Brutalist, Terminal, Campfire, and more. One line to switch. Dark mode included.</p>
      </div>
      <div class="features__item">
        <img src="/icons/controls.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>Reader Controls</h3>
        <p>Visitors choose dark mode, font size, content width, and focus mode. Preferences persist.</p>
      </div>
      <div class="features__item">
        <img src="/icons/templates.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>5 Page Templates</h3>
        <p>Default, landing, guide, tool, and longform. Pick the right layout for every page.</p>
      </div>
      <div class="features__item">
        <img src="/icons/zeroflash.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>Zero-Flash Loading</h3>
        <p>Themes load before the browser paints. No flicker, no wrong colors, no layout shift.</p>
      </div>
      <div class="features__item">
        <img src="/icons/mobile.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>Mobile Editor</h3>
        <p>A built-in PWA at /mobile. Draft and publish from your phone — no app store required.</p>
      </div>
      <div class="features__item">
        <img src="/icons/fork.svg" alt="" width="40" height="40" style="margin-bottom:.15rem" />
        <h3>Fork and Go</h3>
        <p>Clone, edit site.config.ts, push. Your site is live on Cloudflare Pages in 30 seconds.</p>
      </div>
    </div>
    <div class="features__dots" role="tablist" aria-label="Feature navigation">
      {[0,1,2,3,4,5].map((i) => (
        <button
          class={`features__dot ${i === 0 ? "is-active" : ""}`}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-label={`Feature ${i + 1}`}
          data-index={i}
        />
      ))}
    </div>
  </section>

  <section class="clone-cta">
    <div class="container">
      <div class="clone-cta__row">
        <span class="clone-cta__label">Get Started</span>
        <div class="clone-cta__box">
          <code id="clone-url">git clone https://github.com/danrichardson/loomwork.git my-site</code>
          <button class="clone-cta__copy" aria-label="Copy to clipboard" data-copy>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
        <a href="https://github.com/danrichardson/loomwork" class="clone-cta__link" target="_blank" rel="noopener">
          View on GitHub →
        </a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* Single-viewport homepage — desktop only */
  @media (min-width: 768px) {
    body:has(.hero) {
      height: 100vh;
      overflow: hidden;
    }
    body:has(.hero) > main {
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    body:has(.hero) > .site-footer {
      margin-block-start: 0;
      padding-block: var(--space-md);
      flex-shrink: 0;
    }
  }
  /* Mobile: normal scroll, compact footer */
  @media (max-width: 767px) {
    body:has(.hero) > .site-footer {
      margin-block-start: var(--space-lg);
      padding-block: var(--space-md);
    }
  }
</style>

<style>
  .hero {
    padding: 16px 0 6px;
    text-align: center;
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-block-end: 4px;
    letter-spacing: -0.025em;
    position: relative;
    display: inline-block;
  }

  .hero__icon {
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-right: 0.3em;
    opacity: 0.7;
  }

  .hero__tagline {
    font-size: var(--text-lg);
    color: var(--color-accent);
    font-weight: 600;
    margin-block-end: 4px;
  }

  .hero__description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin-inline: auto;
    margin-block-end: 12px;
  }

  .hero__actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__actions .btn {
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  /* ── Feature rotator ───────────────────────────────── */
  .features {
    padding: 4px 0 8px;
    text-align: center;
  }

  .features__rotator {
    display: grid;
    max-width: 32rem;
    margin-inline: auto;
  }

  .features__item {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
  }

  .features__item.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .features__item.is-exiting {
    opacity: 0;
    transform: translateY(-12px);
  }

  .features__icon {
    color: var(--color-accent);
    margin-block-end: var(--space-xs);
    display: block;
  }

  .features__item h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    margin-block-end: 2px;
    color: var(--color-text);
  }

  .features__item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading);
    max-width: 28rem;
  }

  .features__dots {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-block-start: 6px;
  }

  .features__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .features__dot.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.2);
  }

  .features__dot:hover:not(.is-active) {
    border-color: var(--color-text-muted);
  }

  /* ── Clone CTA ─────────────────────────────────────── */
  .clone-cta {
    padding: var(--space-sm) 0;
    text-align: center;
    margin-block-start: auto;
  }

  .clone-cta__label {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .clone-cta__row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  .clone-cta__box {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: #1c1917;
    color: #f1f5f9;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    max-width: 100%;
    overflow-x: auto;
  }

  .clone-cta__box code {
    white-space: nowrap;
    color: #f1f5f9;
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .clone-cta__copy {
    flex-shrink: 0;
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius);
    color: #f1f5f9;
    padding: 4px 6px;
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition);
  }

  .clone-cta__copy:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.3);
  }

  .clone-cta__copy.copied {
    color: #4ade80;
    border-color: #4ade80;
  }

  .clone-cta__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .clone-cta__link:hover {
    text-decoration: underline;
  }

  /* ── Mobile adjustments ────────────────────────────── */
  @media (max-width: 767px) {
    .hero { padding: 12px 0 4px; }
    .hero__title { font-size: clamp(1.8rem, 8vw, 2.5rem); }
    .hero__description { font-size: var(--text-sm); margin-block-end: 8px; }
    .hero__actions .btn { padding: 0.3rem 0.7rem; font-size: 0.8rem; }
    .features { padding: 4px 0 6px; }
    .clone-cta { margin-block-start: var(--space-md); }
    .clone-cta__box { font-size: 0.75rem; padding: 0.5rem 0.75rem; }
  }
</style>

<script>
  const items = document.querySelectorAll('.features__item');
  const dots = document.querySelectorAll('.features__dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function show(index: number) {
    const prev = items[current];
    const next = items[index];

    // Exit current
    prev.classList.remove('is-active');
    prev.classList.add('is-exiting');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');

    // After exit transition, enter new
    setTimeout(() => {
      prev.classList.remove('is-exiting');
      next.classList.add('is-active');
      dots[index].classList.add('is-active');
      dots[index].setAttribute('aria-selected', 'true');
      current = index;
    }, 300);
  }

  function advance() {
    show((current + 1) % items.length);
  }

  // Auto-rotate every 4 seconds
  timer = setInterval(advance, 4000);

  // Click dots to jump
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      if (i === current) return;
      clearInterval(timer);
      show(i);
      timer = setInterval(advance, 4000);
    });
  });

  // Pause on hover
  const rotator = document.querySelector('.features__rotator');
  rotator?.addEventListener('mouseenter', () => clearInterval(timer));
  rotator?.addEventListener('mouseleave', () => {
    timer = setInterval(advance, 4000);
  });

  // Copy clone URL to clipboard
  const copyBtn = document.querySelector('[data-copy]');
  const cloneUrl = document.getElementById('clone-url');
  copyBtn?.addEventListener('click', async () => {
    if (!cloneUrl) return;
    try {
      await navigator.clipboard.writeText(cloneUrl.textContent || '');
      copyBtn.classList.add('copied');
      setTimeout(() => copyBtn.classList.remove('copied'), 2000);
    } catch {}
  });
</script>
