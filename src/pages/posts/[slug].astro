---
import { getCollection } from "astro:content";
import Content from "../../layouts/Content.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const sorted = [...posts].sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return sorted.map((post, i) => {
    const prev = sorted[i - 1]; // newer (up the list)
    const next = sorted[i + 1]; // older (down the list)
    return {
      params: { slug: post.id.replace(/\.mdx?$/, "") },
      props: {
        post,
        prevPost: prev ? { title: prev.data.title, slug: prev.id.replace(/\.mdx?$/, "") } : null,
        nextPost: next ? { title: next.data.title, slug: next.id.replace(/\.mdx?$/, "") } : null,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content: RenderedContent, headings } = await post.render();
---

<Content
  title={post.data.title}
  description={post.data.description}
  template="default"
  hero_image={post.data.hero_image}
  hero_alt={post.data.hero_alt}
  date_updated={post.data.date}
  headings={headings}
  body={post.body}
  prevLink={prevPost ? { title: prevPost.title, href: `/posts/${prevPost.slug}/` } : null}
  nextLink={nextPost ? { title: nextPost.title, href: `/posts/${nextPost.slug}/` } : null}
>
  <div class="post-meta">
    <span class="post-meta__author">By {post.data.author}</span>
    {post.data.tags.length > 0 && (
      <div class="post-meta__tags">
        {post.data.tags.map((tag) => (
          <span class="post-meta__tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
  <RenderedContent />

  {(prevPost || nextPost) && (
    <nav class="post-nav" aria-label="Post navigation">
      {prevPost ? (
        <a href={`/posts/${prevPost.slug}/`} class="post-nav__link post-nav__link--prev">
          <span aria-hidden="true">&larr;</span> {prevPost.title}
        </a>
      ) : <span />}
      {nextPost && (
        <a href={`/posts/${nextPost.slug}/`} class="post-nav__link post-nav__link--next">
          {nextPost.title} <span aria-hidden="true">&rarr;</span>
        </a>
      )}
    </nav>
  )}
</Content>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-block-end: var(--space-lg);
    flex-wrap: wrap;
  }

  .post-meta__author {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .post-meta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .post-meta__tag {
    font-size: 0.75rem;
    padding: 0.125rem var(--space-sm);
    background: var(--color-surface, #f1f5f9);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  :global([data-dark="true"]) .post-meta__tag {
    background: #1e293b;
    color: #94a3b8;
    border-color: var(--color-border);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md, 1rem);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-xl, 2rem);
    margin-top: var(--space-xl, 2rem);
  }

  .post-nav__link {
    color: var(--color-accent);
    text-decoration: none;
    font-size: var(--text-sm, 0.875rem);
    transition: color var(--transition, 0.2s ease);
  }

  .post-nav__link:hover {
    color: var(--color-accent-hover);
  }

  .post-nav__link--next {
    margin-inline-start: auto;
    text-align: end;
  }

  @media (max-width: 480px) {
    .post-nav {
      flex-direction: column;
      gap: var(--space-sm, 0.5rem);
    }

    .post-nav__link--next {
      margin-inline-start: 0;
      text-align: start;
    }
  }
</style>
